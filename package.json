{
  "name": "sonarqube-mcp-monorepo",
  "private": true,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/bhayanak/sonarqube-mcp-server"
  },
  "scripts": {
    "build": "pnpm -r run build",
    "dev": "pnpm --filter sonarqube-mcp-server run dev",
    "test": "pnpm -r run test",
    "test:coverage": "pnpm --filter sonarqube-mcp-server run test:coverage",
    "lint": "pnpm -r run lint",
    "lint:fix": "pnpm -r run lint:fix",
    "typecheck": "pnpm -r run typecheck",
    "format": "prettier --check \"packages/**/*.ts\"",
    "format:fix": "prettier --write \"packages/**/*.ts\"",
    "package": "pnpm -r run package",
    "validate": "pnpm typecheck && pnpm lint && pnpm test && pnpm format",
    "ci": "pnpm run typecheck && pnpm run lint && pnpm run test:coverage && pnpm run format && pnpm run build && pnpm run package"
  },
  "devDependencies": {
    "prettier": "^3.5.3"
  },
  "engines": {
    "node": ">=18"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild"
    ]
  }
}